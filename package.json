{
  "name": "salesfin-task",
  "version": "1.0.0",
  "description": "Express + TypeScript + Knex + PostgreSQL + Redis backend task",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "migrate": "knex --knexfile src/infra/db/knexfile.js migrate:latest",
    "seed": "knex --knexfile src/infra/db/knexfile.js seed:run",
    "test": "jest --runInBand --forceExit",
    "test:unit": "jest --config jest.unit.config.js",
    "test:unit:cov": "jest --config jest.unit.config.js --coverage",
    "smoke": "bash scripts/smoke-test.sh",
    "concurrency": "bash scripts/concurrency-test.sh",
    "concurrency:ab": "bash scripts/concurrency-ab.sh"
  },
  "dependencies": {
    "express": "^4.18.3",
    "ioredis": "^5.3.2",
    "knex": "^3.1.0",
    "pg": "^8.11.5",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.12.7",
    "@types/supertest": "^6.0.2",
    "jest": "^29.7.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.1.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.5"
  }
}
