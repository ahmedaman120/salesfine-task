# Application
PORT=3000
NODE_ENV=development

# PostgreSQL (Knex)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=salesfin
DB_USER=salesfin
DB_PASSWORD=salesfin

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Cache TTL in seconds (products list)
CACHE_TTL=120

# Distributed lock TTL in milliseconds (ticket creation)
LOCK_TTL_MS=5000
